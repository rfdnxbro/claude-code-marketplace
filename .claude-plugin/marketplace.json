{
  "name": "custom-marketplace",
  "version": "0.1.0",
  "description": "Claude Codeプラグインのマーケットプレイス",
  "owner": {
    "name": "rfdnxbro"
  },
  "plugins": [
    {
      "name": "claude-code-workflow",
      "source": "./plugins/claude-code-workflow",
      "description": "Claude Code を使う際の個人的な作業スタイル（エージェント編成パターン、文体ガイド、判断ルール等）をスキルとして集約するプラグイン",
      "version": "0.1.0",
      "author": {
        "name": "rfdnxbro"
      },
      "homepage": "https://github.com/rfdnxbro/claude-code-marketplace/tree/main/plugins/claude-code-workflow",
      "repository": "https://github.com/rfdnxbro/claude-code-marketplace",
      "license": "MIT",
      "keywords": [
        "workflow",
        "agent-team",
        "orchestration",
        "writing-style",
        "personal"
      ],
      "category": "workflow"
    },
    {
      "name": "pr-auto-fix",
      "source": "./plugins/pr-auto-fix",
      "description": "PR 作成後に CI 失敗・レビュー・コンフリクトを自動検知し、自明な修正は commit & push、判断要は PR コメントでエスカレーションするプラグイン",
      "version": "0.2.0",
      "author": {
        "name": "rfdnxbro"
      },
      "homepage": "https://github.com/rfdnxbro/claude-code-marketplace/tree/main/plugins/pr-auto-fix",
      "repository": "https://github.com/rfdnxbro/claude-code-marketplace",
      "license": "MIT",
      "keywords": [
        "pull-request",
        "ci",
        "automation",
        "github",
        "monitor"
      ],
      "category": "automation"
    },
    {
      "name": "git-main-sync",
      "source": "./plugins/git-main-sync",
      "description": "新規セッション開始時、git管理下なら現在ブランチに応じてmainブランチをpullまたはfetchで最新化する",
      "version": "0.1.0",
      "author": {
        "name": "rfdnxbro"
      },
      "homepage": "https://github.com/rfdnxbro/claude-code-marketplace/tree/main/plugins/git-main-sync",
      "repository": "https://github.com/rfdnxbro/claude-code-marketplace",
      "license": "MIT",
      "keywords": [
        "git",
        "session-start",
        "hooks",
        "workflow",
        "personal"
      ],
      "category": "workflow"
    }
  ]
}
