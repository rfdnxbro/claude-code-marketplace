{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "if": "Write(*.ts)|Write(*.py)|Write(*.go)|Write(*.js)|Write(*.jsx)|Write(*.tsx)|Write(*.java)|Write(*.rb)|Write(*.rs)|Edit(*.ts)|Edit(*.py)|Edit(*.go)|Edit(*.js)|Edit(*.jsx)|Edit(*.tsx)|Edit(*.java)|Edit(*.rb)|Edit(*.rs)",
        "hooks": [
          {
            "type": "agent",
            "agent": "doc-checker",
            "prompt": "変更されたファイルに関連するドキュメントの整合性をチェックしてください: $ARGUMENTS",
            "timeout": 120,
            "statusMessage": "ドキュメント整合性チェック中..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-summary.sh",
            "timeout": 10,
            "statusMessage": "ドキュメントチェックセッションサマリーを記録中..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-summary.sh",
            "timeout": 10,
            "statusMessage": "エラー発生時のドキュメントチェックログを記録中..."
          }
        ]
      }
    ]
  }
}
