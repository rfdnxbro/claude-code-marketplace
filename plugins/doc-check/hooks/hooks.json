{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "if": "Write(**/*.ts)|Write(**/*.js)|Write(**/*.py)|Write(**/*.go)|Write(**/*.rs)|Write(**/*.java)|Edit(**/*.ts)|Edit(**/*.js)|Edit(**/*.py)|Edit(**/*.go)|Edit(**/*.rs)|Edit(**/*.java)|MultiEdit(**/*.ts)|MultiEdit(**/*.js)|MultiEdit(**/*.py)|MultiEdit(**/*.go)|MultiEdit(**/*.rs)|MultiEdit(**/*.java)",
        "hooks": [
          {
            "type": "agent",
            "agent": "doc-checker",
            "prompt": "変更されたファイルに関連するドキュメントの整合性をチェックしてください: $ARGUMENTS",
            "timeout": 120,
            "statusMessage": "ドキュメント整合性チェック中..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-summary.sh",
            "timeout": 10,
            "statusMessage": "ドキュメントチェックセッションサマリーを記録中..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-summary.sh",
            "timeout": 10,
            "statusMessage": "エラー発生時のドキュメントチェックログを記録中..."
          }
        ]
      }
    ]
  }
}
