{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "if": "not(tool_input.file_path matches '\\.(test|spec)\\.(ts|js|py)$|node_modules/|dist/|build/')",
        "hooks": [
          {
            "type": "agent",
            "agent": "doc-checker",
            "prompt": "変更されたファイルに関連するドキュメントの整合性をチェックしてください: $ARGUMENTS",
            "timeout": 120,
            "statusMessage": "ドキュメント整合性チェック中..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-summary.sh",
            "timeout": 10,
            "statusMessage": "ドキュメントチェックセッションサマリーを記録中..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-summary.sh",
            "timeout": 10,
            "statusMessage": "エラー発生時のドキュメントチェックログを記録中..."
          }
        ]
      }
    ]
  }
}
