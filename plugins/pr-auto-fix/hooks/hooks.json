{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(gh pr create*)",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/detect-pr-create.sh",
            "timeout": 15,
            "statusMessage": "pr-auto-fix: 監視対象を登録中..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh",
            "timeout": 10,
            "statusMessage": "pr-auto-fix: セッション終了時の監視状態を記録中..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh",
            "timeout": 10,
            "statusMessage": "pr-auto-fix: APIエラー発生時の監視状態を記録中..."
          }
        ]
      }
    ]
  }
}
