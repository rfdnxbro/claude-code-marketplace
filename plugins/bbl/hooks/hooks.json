{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/context-check.sh",
            "timeout": 5,
            "statusMessage": "記事コンテキストを確認中..."
          }
        ]
      }
    ],
    "Setup": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/setup.sh",
            "timeout": 30,
            "statusMessage": "BBLプラグインをセットアップ中..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh",
            "timeout": 10,
            "statusMessage": "セッションログを記録中..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh",
            "timeout": 10,
            "statusMessage": "エラー発生時のセッションログを記録中..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "content-writer",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "以下の最後のアシスタントメッセージを参考に、記事作成結果を報告してください: $ARGUMENTS\n\n含める情報: 作成した記事のパス、記事の文字数、含まれるMermaid図の数。"
          }
        ]
      },
      {
        "matcher": "content-reviewer",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "入力（$ARGUMENTS）の last_assistant_message フィールドに含まれる最後のアシスタントメッセージを参考に、レビュー結果（スコアと主要な改善点）を要約してください。"
          }
        ]
      }
    ]
  }
}
