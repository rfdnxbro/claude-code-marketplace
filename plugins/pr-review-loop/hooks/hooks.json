{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/review-summary.sh",
            "timeout": 10,
            "statusMessage": "PRレビューセッションの最終サマリーを記録中..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/review-summary.sh",
            "timeout": 10,
            "statusMessage": "エラー発生時のPRレビューログを記録中..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/review-summary.sh",
            "timeout": 10,
            "statusMessage": "PRレビューセッションのセッション終了ログを記録中..."
          }
        ]
      }
    ]
  }
}
